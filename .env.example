# ChatBI 环境变量配置文件
# 复制此文件为 .env 并填写实际配置

# ==================== 本地开发配置 ====================
# 开发环境默认使用 H2 文件数据库，无需额外安装 MySQL
SERVER_PORT=8081
SPRING_PROFILES_ACTIVE=dev
VITE_DEV_PROXY_TARGET=http://localhost:8081

# ==================== 生产数据库配置（可选） ====================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=chatbi
DB_USER=chatbi
DB_PASSWORD=ChatBI@2026

# ==================== Redis配置（可选，开发环境默认不需要） ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== JWT配置 ====================
JWT_SECRET=chatbi-enterprise-secret-key-min-256-bit-for-jwt-signing
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# ==================== LLM配置 (二选一) ====================

# 选项1: OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# 选项2: 自定义LLM (如DeepSeek、通义千问等)
LLM_API_KEY=your-llm-api-key-here
LLM_BASE_URL=https://api.your-llm-provider.com/v1/chat/completions
LLM_MODEL=gpt-4

# ==================== 邮件配置 (可选) ====================
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_FROM=noreply@chatbi.com

# ==================== 钉钉推送配置 (可选) ====================
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your-token
DINGTALK_SECRET=your-dingtalk-secret

# ==================== 企业微信推送配置 (可选) ====================
WECHAT_CORP_ID=your-corp-id
WECHAT_AGENT_ID=your-agent-id
WECHAT_SECRET=your-wechat-secret

# ==================== 文件上传配置 ====================
UPLOAD_PATH=./uploads
UPLOAD_MAX_SIZE=52428800
