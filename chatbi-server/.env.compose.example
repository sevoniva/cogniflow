# ChatBI docker-compose 部署环境变量模板
# 用法：
# 1. cp chatbi-server/.env.compose.example chatbi-server/.env.compose
# 2. 按实际部署环境修改变量
# 3. docker compose --env-file chatbi-server/.env.compose -f chatbi-server/docker-compose.yml up -d --build

# -----------------------------
# 宿主机端口映射
# -----------------------------
CHATBI_WEB_HOST_PORT=18090
CHATBI_API_HOST_PORT=19091
CHATBI_DB_HOST_PORT=3306
CHATBI_REDIS_HOST_PORT=6379

# -----------------------------
# Spring 运行配置
# 建议单机部署先使用 dev；如果切到 prod，请确保外部反向代理、域名和安全参数完整
# -----------------------------
SPRING_PROFILES=dev
SERVER_PORT=8081
LOG_FILE_PATH=/app/logs/chatbi.log
JAVA_OPTS=-Xms512m -Xmx2g -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/app/logs

# -----------------------------
# 数据库与缓存
# -----------------------------
DB_NAME=chatbi
DB_USERNAME=chatbi
MYSQL_ROOT_PASSWORD=ChatBI@2026
MYSQL_PASSWORD=ChatBI@2026
REDIS_PASSWORD=ChatBI@2026

# -----------------------------
# 安全密钥
# 生产环境务必替换
# -----------------------------
JWT_SECRET=chatbi-enterprise-secret-key-min-256-bit-for-jwt-signing
PASSWORD_SALT=chatbi-salt-2026

# -----------------------------
# AI 总开关
# 当前已验证 Kimi 可用
# -----------------------------
CHATBI_AI_ENABLED=true

# Kimi / Moonshot
KIMI_ENABLED=true
KIMI_API_KEY=

# OpenAI
OPENAI_ENABLED=false
OPENAI_API_KEY=

# 通义千问（直接配置）
QWEN_ENABLED=false
QWEN_API_KEY=

# 阿里云百炼
BAILIAN_ENABLED=false
BAILIAN_API_KEY=

# MiniMax
MINIMAX_ENABLED=false
MINIMAX_API_KEY=

# 通用 OpenAI 兼容接口
GENERIC_ENABLED=false
GENERIC_API_KEY=
GENERIC_API_URL=https://your-api-endpoint.com/v1/chat/completions
GENERIC_MODEL=gpt-3.5-turbo

# -----------------------------
# 订阅推送（EMAIL）
# 未配置时 EMAIL 推送会报“邮件服务未启用”
# -----------------------------
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=465
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_SSL_ENABLE=true

# -----------------------------
# AI 可观测性告警通知（可选）
# channels 支持逗号分隔：EMAIL,DINGTALK,WECHAT
# -----------------------------
AI_OBSERVABILITY_NOTIFY_ENABLED=false
AI_OBSERVABILITY_NOTIFY_CHANNELS=
AI_OBSERVABILITY_NOTIFY_EMAIL_TO=
AI_OBSERVABILITY_NOTIFY_DINGTALK_WEBHOOK=
AI_OBSERVABILITY_NOTIFY_WECHAT_WEBHOOK=
AI_OBSERVABILITY_NOTIFY_SUBJECT_PREFIX=[ChatBI AI告警]
AI_OBSERVABILITY_NOTIFY_MIN_INTERVAL_SECONDS=300
