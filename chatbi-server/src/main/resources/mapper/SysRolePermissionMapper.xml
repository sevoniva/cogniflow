<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chatbi.repository.SysRolePermissionMapper">

    <!-- 根据角色 ID 删除角色权限关联 -->
    <delete id="deleteByRoleId">
        DELETE FROM sys_role_permission WHERE role_id = #{roleId}
    </delete>

    <!-- 批量插入角色权限关联 -->
    <insert id="batchInsert">
        INSERT INTO sys_role_permission (role_id, permission_id, created_at)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.roleId}, #{item.permissionId}, #{item.createdAt})
        </foreach>
    </insert>

</mapper>
